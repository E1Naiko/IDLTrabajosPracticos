# ==========================================
# Archivos temporales y de compilación de Quartus II
# ==========================================
db/
incremental_db/
simulation/
greybox_tmp/
hc_output/
/output_files/

# Reportes y bitácoras de texto de Quartus
*.rpt
*.summary
*.sof
*.pof
*.jdi
*.pin
*.done
*.sld
*.smsg
*.qws

# Archivos del sistema y configuraciones locales del usuario
*.bak
*.orig

# ==========================================
# Prerequisites & Object files
# ==========================================
*.d
*.o
*.ko
*.obj
*.elf

# ==========================================
# Linker output & Precompiled Headers
# ==========================================
*.ilk
*.map
*.exp
*.gch
*.pch

# ==========================================
# Libraries & Shared objects (inc. Windows DLLs)
# ==========================================
*.lib
*.a
*.la
*.lo
*.dll
*.so
*.so.*
*.dylib

# ==========================================
# Executables & Debug files
# ==========================================
*.exe
*.out
*.app
*.i*86
*.x86_64
*.hex
*.dSYM/
*.su
*.idb
*.pdb

# ==========================================
# Kernel Module Compile Results
# ==========================================
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# ==========================================
# GNU Octave / MATLAB
# ==========================================
*.oct               # compiled C++ oct-files
*.mex*              # compiled MEX files (.mex, .mexa64, .mexw64, .mexmaci64, etc.)
*.mat               # binary Octave/MATLAB data files (often huge; comment out if you want to track them)
*.fig               # MATLAB/Octave figure files
octave-workspace    # saved workspace when you run `save`
octave-core*        # core dump if Octave crashes
.octave_hist        # command history
*~                  # backup files from editors (e.g. script.m~)
*.asv               # Octave/MATLAB autosave files
.jitcache           # Octave's JIT cache
